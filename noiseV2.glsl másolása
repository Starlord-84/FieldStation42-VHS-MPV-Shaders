#define INTENSITY 0.006

float hash(vec2 p)
{
    p = fract(p * vec2(443.897,441.423));
    p += dot(p, p + 19.19);
    return fract(p.x * p.y);
}

vec4 hook()
{
    vec2 uv = HOOKED_pos;

    vec4 color = HOOKED_tex(uv);

    float t = float(frame);

    //--------------------------------------------------
    // Finom luminancia zaj
    //--------------------------------------------------

    float grain = hash(uv * HOOKED_size * 0.75 + frame);

    grain =
        (grain - 0.5) * 2.0;

    //--------------------------------------------------
    // Fényesség
    //--------------------------------------------------

    float luma =
        dot(
            color.rgb,
            vec3(0.299,0.587,0.114));

    float strength =
        INTENSITY *
        pow(1.0 - luma,1.4);

    //--------------------------------------------------
    // Kis RGB eltérés
    //--------------------------------------------------

    float r =
        grain;

    float g =
        grain * 0.85;

    float b =
        grain * 0.90;

    color.rgb += grain * strength;

    return color;
}
